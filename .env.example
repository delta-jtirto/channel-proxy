# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Credential Encryption (32-byte hex key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
CREDENTIALS_ENCRYPTION_KEY=

# ============================================================
# Upstash QStash (webhook queue)
# ============================================================
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Override worker URL (defaults to VERCEL_URL/api/workers/process-webhook)
# QSTASH_WORKER_URL=

# ============================================================
# Vercel Cron Secret
# ============================================================
CRON_SECRET=

# ============================================================
# Google OAuth (Gmail integration)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/gmail-callback
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# ============================================================
# Microsoft Azure AD (Outlook/M365 integration) — Phase 2
# ============================================================
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_REDIRECT_URI=https://your-app.vercel.app/api/auth/microsoft-callback

# ============================================================
# AI BPO redirect URL (after OAuth callbacks)
# ============================================================
AI_BPO_URL=http://localhost:5173

# ============================================================
# Meta WhatsApp Embedded Signup v4 (optional)
# Required only when frontend uses the "Quick" connect tab.
# App ID/Secret: Meta Developer Dashboard → App → Settings → Basic
# Default verify token: any random string; reused per-account because
# Embedded Signup doesn't ask the user for one.
# ============================================================
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN_DEFAULT=
