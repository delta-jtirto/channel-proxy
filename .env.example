# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Credential Encryption (32-byte hex key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
CREDENTIALS_ENCRYPTION_KEY=

# ============================================================
# Upstash QStash (webhook queue)
# ============================================================
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Override worker URL (defaults to VERCEL_URL/api/workers/process-webhook)
# QSTASH_WORKER_URL=

# ============================================================
# Vercel Cron Secret
# ============================================================
CRON_SECRET=

# ============================================================
# Google OAuth (Gmail integration)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/gmail-callback
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# ============================================================
# Microsoft Azure AD (Outlook/M365 integration) — Phase 2
# ============================================================
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_REDIRECT_URI=https://your-app.vercel.app/api/auth/microsoft-callback

# ============================================================
# AI BPO redirect URL (after OAuth callbacks)
# ============================================================
AI_BPO_URL=http://localhost:5173

# ============================================================
# Meta WhatsApp Embedded Signup v4 (optional)
# Required only when frontend uses the "Quick" connect tab.
# App ID/Secret: Meta Developer Dashboard → App → Settings → Basic
# Default verify token: any random string; reused per-account because
# Embedded Signup doesn't ask the user for one.
# ============================================================
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN_DEFAULT=

# ============================================================
# Support consumer (separate from BPO)
# Accounts created with delivery_target='support' get their inbound
# messages forwarded to this URL after the BPO write path. The
# X-Webhook-Token header carries SUPPORT_WEBHOOK_SECRET, which must
# match the same-named secret on the AI CS BPO Supabase project's
# edge functions (set via `supabase secrets set` from that repo).
# Leave blank to disable Support forwarding entirely.
# ============================================================
SUPPORT_WEBHOOK_URL=https://udeflfcdqgjkgkmrazxk.supabase.co/functions/v1/support-channel-inbound
SUPPORT_WEBHOOK_SECRET=

# ============================================================
# Twilio — Voice/Video channel (phone spike)
# See docs/voice-spike.md. Console → Account Info + API keys + TwiML App.
# ============================================================
TWILIO_ACCOUNT_SID=          # Account SID (Console → Account Info)
TWILIO_AUTH_TOKEN=           # Auth Token — validates inbound webhook signatures
TWILIO_API_KEY_SID=          # Standard API Key SID — signs AccessTokens
TWILIO_API_KEY_SECRET=       # API Key Secret (shown once at key creation)
TWILIO_TWIML_APP_SID=        # TwiML App SID — outbound only; leave blank for inbound-only spike
TWILIO_PHONE_NUMBER=         # E.164 Twilio number that receives inbound calls
